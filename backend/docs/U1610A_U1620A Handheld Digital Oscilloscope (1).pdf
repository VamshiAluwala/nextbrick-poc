<script>
document.addEventListener('DOMContentLoaded', function() {
    // Function to delete a cookie
    function deleteGatedCookie(name, domain) {
        document.cookie = name + "=; expires=Thu, 01 Jan 1970 00:00:00 UTC; domain=" + domain + "; path=/;";
    }

    // Delete the "gated" cookie for the specified domains
    deleteGatedCookie('gated', '.keysight.com');
    deleteGatedCookie('gated', 'keysight.com');
    deleteGatedCookie('gated', 'www.keysight.com');
    deleteGatedCookie('gated', 'stgwww.keysight.com');
    deleteGatedCookie('gated', location.hostname);
    document.cookie =  'gated=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';

});

</script>
