    <div class="generic-html parbase aem-GridColumn aem-GridColumn--default--12">

<script type="text/javascript">

/* Code for handling known used from Eloqua Landing Pages using XNGATE cookie */

function tempGetCookie(name) {
    let cookies = document.cookie.split(';');
    for (let i = 0; i < cookies.length; i++) {
        let position = cookies[i].indexOf('=');
        if (position > 0 && position < cookies[i].length - 1) {
            let x = cookies[i].substr(0, position);
            let y = cookies[i].substr(position + 1);
            x = x.replace(/^\s+|\s+$/g, '');
            if (x == name) {
                return unescape(y);
            }
        }
    }
    return '';
}
function tempGetCookieSubValue(name, subKey, splitBy) {
    let cookieValue = tempGetCookie(name);
    if (cookieValue == null || cookieValue == '')
        return '';
    let cookieSubValue = cookieValue.split(splitBy);
    for (let i = 0; i < cookieSubValue.length; i++) {
        let pair = cookieSubValue[i].split('=');
        if (pair.length > 1) {
            if (pair[0] == subKey) {
                return pair[1];
            }
        }
    }
    return '';
}

function checkFormCookieByXngateCookie() {

    var cookieItemKey = 'xngate';
    var cookieItem = tempGetCookie(cookieItemKey);

    var isRefElqLandingPage = document.referrer.indexOf('connectlp.keysight.com') > -1;

    
    if (!!cookieItem  || isRefElqLandingPage) { //if xngate exists or referrer is connectlp 
        console.log("xngate exists or referrer connectlp");

        var lsItemKey = 'Eloqua_form';
        var lsItem = localStorage.getItem(lsItemKey);


        if (!lsItem) /* Eloqua form local storage does not exist */ 
        {
            console.log("create ls object");

            let elqCustomerGuid = tempGetCookieSubValue('ELOQUA', 'GUID', '&');
            
            let item;
            var expirationTime = Date.now() + 24 * 60 * 60 * 1000; // 1 day from now in milliseconds
            item = { value: 'Eloqua_form_visited', expiresAt: expirationTime, GUID: elqCustomerGuid};
            localStorage.setItem(lsItemKey, JSON.stringify(item));

            console.log("ls object created : " + localStorage.getItem(lsItemKey));
        }
        else {
            console.log("ls object exists: " + localStorage.getItem(lsItemKey));
        }
        
    } else { //if localstorage is not present then display the form
        //Display body
        console.log("xngate doesn't exist");
    } 
}

checkFormCookieByXngateCookie();

</script>
</div>
