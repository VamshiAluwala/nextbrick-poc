    <script>
    var digitalData = window.digitalData || {
        "autoPageView": true,
        "applicationInfo": {
            "applicationSoftwareFamily": "",
            "applicationSoftwareBundle": "",
            "application": "None"
        },
        "punchOut": {
            "companyName": "",
            "type": ""
        },
        "page": {
            "pageInfo": {
                "localizedPageTitle": "",
                "URL": "",
                "englishPageName": "",
            },
        },
        "events":[],
        "userInfo":{
            "loggedInStatus": "",
            "emailAddress": ""
        },
        "pageAttributes":{
            "countryCode": "",
            "languageCode": "",
            "pageHierarchy0": "",
            "pageHierarchy1": "",
            "pageHierarchy2": "",
            "pageHierarchy3": "",
            "pageHierarchy4": ""
        },
        "form":{
        	"formInfo":{
    			"formID":"",
                "formStatus":""
		    }
        } 
    };

    (function() {
        // cookie reader by Lea Verou: http://lea.verou.me/2009/12/reading-cookies-the-regular-expression-way/
        function getCookie(name) {
            // Escape regexp special characters
            name = name.replace(/([.*+?^=!:()|[\]\/\\])/g, '\\$1');
        
            var regex = new RegExp('(?:^|;)\\s?' + name + '=(.*?)(?:;|$)', 'i'),
                match = document.cookie.match(regex);
        
            return match && unescape(match[1]);
        }

        window.digitalData.pageAttributes.countryCode = "zz".toUpperCase();
	    window.digitalData.pageAttributes.languageCode = "en";

        
            window.digitalData.pageAttributes.pageHierarchy0 = "Home";
        
            window.digitalData.pageAttributes.pageHierarchy1 = "other pages";
        
            window.digitalData.pageAttributes.pageHierarchy2 = "PDF Asset Page";
        
        document.addEventListener('DOMContentLoaded', function() {
            var attrs = window.digitalData.pageAttributes;

            var breadcrumbEl = document.getElementById('breadcrumb');
            var breadcrumbData = breadcrumbEl ? breadcrumbEl.getAttribute('data-breadcrumb') : null;

            if (!breadcrumbData || breadcrumbData.trim() === '') {
                if (!attrs.pageHierarchy0 || attrs.pageHierarchy0.trim() === '') {
                    attrs.pageHierarchy0 = 'Not set';
                }
                return;
            }

            var breadcrumbJson;
            try {
                breadcrumbJson = JSON.parse(breadcrumbData);
            } catch (e) {
                if (!attrs.pageHierarchy0 || attrs.pageHierarchy0.trim() === '') {
                    attrs.pageHierarchy0 = 'Not set';
                }
                return;
            }

            var keys = (breadcrumbJson && typeof breadcrumbJson === 'object') ? Object.keys(breadcrumbJson) : [];
            if (keys.length === 0) {
                if (!attrs.pageHierarchy0 || attrs.pageHierarchy0.trim() === '') {
                    attrs.pageHierarchy0 = 'Not set';
                }
                return;
            }

            keys.sort(function(a, b) { return Number(a) - Number(b); });
            var maxIndex = -1;
            var parts = [];

            for (var i = 0; i < keys.length; i++) {
                var val = breadcrumbJson[keys[i]];
                if (val != null && val.toString().trim() !== '') {
                    attrs['pageHierarchy' + keys[i]] = val;
                    parts.push(val);
                    if (Number(keys[i]) > maxIndex) {
                        maxIndex = Number(keys[i]);
                    }
                }
            }

            var nextIndex = maxIndex + 1;
            var serverVal = attrs['pageHierarchy' + nextIndex];
            while (serverVal != null && serverVal.toString().trim() !== '') {
                parts.push(serverVal);
                nextIndex++;
                serverVal = attrs['pageHierarchy' + nextIndex];
            }

            if (parts.length > 0) {
                attrs.pageHierarchyComplete = parts.join('|');
            }
        });

        var loggedInStatusVal = getCookie('USER_CREDENTIALS');
        if (loggedInStatusVal == 'VALID') {
            loggedInStatusVal = 'Logged In';
            emailAddressVal = getCookie('USER_EMAIL');
            window.digitalData.userInfo.emailAddress = emailAddressVal;
        } else {
            loggedInStatusVal = 'Not Logged In';
        }
        window.digitalData.userInfo.loggedInStatus = loggedInStatusVal;
        
        let punchOutUserName = getCookie('PUNCHOUT_USERNAME');
        if(punchOutUserName != null) {
            const [username, type] = punchOutUserName.split('|');
            if (window.digitalData.applicationInfo) {
                window.digitalData.applicationInfo.application = 'eProc';
            }
            
            if (window.digitalData.punchOut) {
                window.digitalData.punchOut.companyName = username.replace('##', '');
                window.digitalData.punchOut.type = type;
            } 
        }
           
    })();
</script>
    


    
    
